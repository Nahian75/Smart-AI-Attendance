# ================================================================
#  MediaMTX config — runs LOCALLY on the edge machine (start_edge.bat).
#  Pushes each camera's ANNOTATED feed (with bounding box overlays —
#  edge_node's own detection output, not the raw camera RTSP) out as
#  SRT to the cloud VM's MediaMTX ingest
#  (infra/mediamtx/mediamtx.cloud.yml), so the dashboard can view live
#  video without opening any inbound port on your home network (the
#  edge always initiates the connection).
#
#  The RTSP camera URL itself is NOT configured here — edge_node
#  already pulls each camera's real RTSP URL dynamically from the
#  backend's registered camera list and serves the annotated result
#  at http://edge_node:8001/stream/<camera_id> (same Docker network,
#  see docker-compose.edge.yml). This file only needs to know each
#  camera's id (the UUID shown in the dashboard's Cameras page) to
#  push it out — add/remove entries in the CAMERA_IDS list below.
#
#  `%CLOUD_HOST%` and `%MTX_SRTPUBLISHPASS%` are substituted from
#  .env.edge by start_edge.bat before this file is mounted into the
#  mediamtx container.
# ================================================================

logLevel: info

# No local RTSP relay needed — runOnInit pushes directly from
# edge_node's annotated MJPEG output for each camera below.
rtsp: no
hls: no
webrtc: no
srt: no

# ── Camera IDs to push ─────────────────────────────────────────
# runOnInit/runOnInitRestart are path-level hooks, not global — this
# path has no source/stream of its own, it only exists to host the
# init hook. One `while ... done &` loop per camera inside it. Get
# each camera's id from the dashboard's Cameras page (edit view URL /
# API response). Duplicate the loop block per camera, changing only
# CAMERA_ID_n — note the "|" block (not ">") to keep real line breaks,
# since this is an actual shell script, not a single folded line.
paths:
  _srt_push:
    # Low-latency flags — an uncapped source resolution/bitrate overwhelms
    # encode CPU and home upload bandwidth, and ffmpeg buffers (does not
    # drop) frames it can't keep up with, so latency grows unbounded over
    # time if these aren't set. Adjust scale/bitrate to your upload speed.
    runOnInit: |
      sh -c '
      while true; do
        ffmpeg -fflags nobuffer -flags low_delay -f mjpeg -i http://edge_node:8001/stream/CAMERA_ID_1 \
          -vf scale=960:-2 -r 10 \
          -c:v libx264 -preset ultrafast -tune zerolatency -profile:v baseline \
          -bf 0 -sc_threshold 0 \
          -b:v 800k -maxrate 800k -bufsize 800k -g 10 \
          -max_delay 0 -flush_packets 1 -f mpegts \
          "srt://%CLOUD_HOST%:8890?streamid=publish:CAMERA_ID_1&passphrase=%MTX_SRTPUBLISHPASS%&pkt_size=1316&latency=200"
        sleep 2
      done &
      wait
      '
    runOnInitRestart: yes
