# ─── Database ───────────────────────────────────────
POSTGRES_USER=attendance
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=attendance_db

# ─── Redis ──────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ─── Backend ────────────────────────────────────────
SECRET_KEY=generate_with_openssl_rand_hex_32
ENVIRONMENT=production
FACE_ENCRYPTION_KEY=generate_with_python_fernet
CONFIDENCE_THRESHOLD=0.82
COOLDOWN_MINUTES=5
EVENT_RETENTION_DAYS=90

# ─── Edge node ──────────────────────────────────────
TENANT_ID=demo
DEVICE=cuda
# Shared secret between backend and edge nodes for event ingest.
# Generate with: openssl rand -hex 32
# Must be non-empty in ENVIRONMENT=production (startup will refuse to start if blank).
EDGE_TOKEN=

# ─── Frontend ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Edge MJPEG stream: empty = via nginx proxy (/stream/ → edge:8001).
# For dev without nginx, set to http://localhost:8001
NEXT_PUBLIC_EDGE_URL=
