# ================================================================
#  Cloud (GCP VM) environment template.
#
#  In CI: .github/workflows/deploy-cloud.yml writes .env directly on
#  the VM from GitHub repo secrets on every push to `cloud` — this
#  file is not used and no secrets are ever committed to the repo.
#
#  Manual/local bootstrap only: copy this to .env and fill in real
#  values. start_cloud.sh falls back to doing this automatically if
#  .env doesn't exist yet (e.g. testing outside of CI).
# ================================================================

# ─── Database ───────────────────────────────────────
POSTGRES_USER=attendance
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=attendance_db

# ─── Redis ──────────────────────────────────────────
# Must match REDIS_PASSWORD in the edge node's .env.edge
REDIS_PASSWORD=changeme_redis_password

# ─── Backend ────────────────────────────────────────
SECRET_KEY=generate_with_openssl_rand_hex_32
ENVIRONMENT=production
FACE_ENCRYPTION_KEY=generate_with_python_fernet
CONFIDENCE_THRESHOLD=0.82
COOLDOWN_MINUTES=5
EVENT_RETENTION_DAYS=90
ALLOWED_ORIGINS=http://35.253.8.57,http://localhost

# ─── Edge node auth ─────────────────────────────────
# Leave blank. verify_edge_token (backend/app/dependencies.py) only guards
# /api/v1/enrollment/export-edge, but edge/src/main.py's get_token() uses
# this as the Bearer token for EVERY backend call if set (cameras,
# heartbeat, etc.) — those require a real login JWT, not this raw shared
# secret, so setting it breaks camera loading. The edge authenticates via
# EDGE_USER/EDGE_PASS login instead (see .env.edge).
TENANT_ID=demo
EDGE_TOKEN=

# ─── Frontend ───────────────────────────────────────
# Point these at the VM's public IP or domain (not localhost — the
# frontend is built once and served to browsers outside the VM).
NEXT_PUBLIC_API_URL=http://35.253.8.57
NEXT_PUBLIC_WS_URL=ws://35.253.8.57
NEXT_PUBLIC_EDGE_URL=
# MediaMTX HLS output — camera video from the edge node, played by the
# dashboard's CameraFeed component. Empty = falls back to MJPEG via
# NEXT_PUBLIC_EDGE_URL/nginx (works only if edge_node is on the same
# docker network, i.e. never in this cloud/edge split).
NEXT_PUBLIC_HLS_URL=http://35.253.8.57:8888

# ─── MediaMTX (SRT video ingest from edge) ──────────
# Generate with: openssl rand -hex 16 — must match in edge/mediamtx.edge.yml
MTX_SRTPUBLISHPASS=changeme_srt_passphrase

# ─── Demo seed credentials ───────────────────────────
# seed.py currently hardcodes admin@demo.com / admin123 — change it there
# (backend/seed.py) if you want a different demo login. Not read from env.
