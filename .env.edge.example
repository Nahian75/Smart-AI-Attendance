# ================================================================
#  Edge node environment — copy to .env.edge and fill in.
#  start_edge.bat creates this automatically from this template on
#  first run if .env.edge does not exist yet.
# ================================================================

# ─── Cloud VM connection ────────────────────────────
CLOUD_HOST=35.253.8.57

# Must match REDIS_PASSWORD in the cloud VM's .env.cloud
REDIS_PASSWORD=changeme_redis_password

# Must match EDGE_TOKEN in the cloud VM's .env.cloud (leave both blank to
# use EDGE_USER/EDGE_PASS login instead of a static token)
TENANT_ID=demo
EDGE_TOKEN=
EDGE_USER=admin@demo.com
EDGE_PASS=admin123

# ─── SRT video push (MediaMTX) ──────────────────────
# Must match MTX_SRTPUBLISHPASS in the cloud VM's .env.cloud
MTX_SRTPUBLISHPASS=changeme_srt_passphrase
